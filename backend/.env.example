# Local dev — SQLite, no install required
DATABASE_URL=sqlite:///./findash.db

# Production — uncomment and set Postgres URL (used by Docker + Railway)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/findash

REDIS_URL=redis://localhost:6379
ALLOWED_ORIGINS=
QUOTE_TTL=60
HISTORY_TTL=300
NAME_TTL=86400
