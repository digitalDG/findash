# ── Database ──────────────────────────────────────────────────────────────────
# Local dev — SQLite, no install required
DATABASE_URL=sqlite:///./findash.db

# Production — set to your Postgres URL (Railway provides this automatically)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/findash

# ── Redis ─────────────────────────────────────────────────────────────────────
# Railway provides REDIS_URL automatically when you add the Redis plugin
REDIS_URL=redis://localhost:6379

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (in addition to localhost defaults)
# Production: set to your Railway frontend URL, e.g. https://findash.up.railway.app
ALLOWED_ORIGINS=

# ── Frontend URL ──────────────────────────────────────────────────────────────
# Used in password-reset emails — must be your production frontend URL
# Production: set to your Railway frontend URL, e.g. https://findash.up.railway.app
FRONTEND_URL=http://localhost:5173

# ── Cache TTLs (seconds) ──────────────────────────────────────────────────────
QUOTE_TTL=60
HISTORY_TTL=300
NAME_TTL=86400

# ── Microsoft Graph email (Azure App Registration) ────────────────────────────
# Required for price alerts and transactional emails (profile changes, password reset)
MS_CLIENT_ID=
MS_REFRESH_TOKEN=
MS_SENDER_EMAIL=you@outlook.com
