{
  "name": "findash-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest --project=unit",
    "test:stories": "vitest --project=storybook",
    "lint": "eslint src",
    "format": "prettier --write src",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "git -C .. config core.hooksPath frontend/.husky"
  },
  "dependencies": {
    "@sentry/react": "^10.57.0",
    "@tanstack/react-query": "^5.101.0",
    "lucide-react": "^1.17.0",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "posthog-js": "^1.386.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^9.11.0",
    "@storybook/addon-a11y": "^10.4.4",
    "@storybook/addon-docs": "^10.4.4",
    "@storybook/addon-vitest": "^10.4.4",
    "@storybook/react-vite": "^10.4.4",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.11.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "eslint-plugin-storybook": "^10.4.4",
    "globals": "^15.9.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "prettier": "^3.3.0",
    "storybook": "^10.4.4",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.7.0",
    "vite": "^5.3.4",
    "vitest": "^4.1.8"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
